#!/usr/bin/env bash

PATH="./node_modules/.bin:$PATH"

[[ -f "./.env" ]] && source ./.env

function build {
  rm -rf ./dist

  # Build JavaScript bundles with esbuild (minified, ES2022 target)
  esbuild ./src/core/index.ts --bundle --minify --format=esm --target=es2022 --outfile=./dist/core/index.js --platform=browser
  # esbuild ./src/extensions/disable.ts --bundle --minify --format=esm --outfile=./dist/extensions/disable.js --platform=browser

  # Generate TypeScript declarations
  tsc --project ./tsconfig.json --emitDeclarationOnly --declaration --declarationDir ./dist/types --outDir ./dist/types

  # Report bundle sizes
  echo ""
  echo "Bundle sizes:"
  ls -lh ./dist/core/index.js ./dist/extensions/*.js 2>/dev/null | awk '{print $9, $5}'
}

function test {
  node --import=tsx --test "./src/**/*.test.ts"
}

function format {
  prettier --write "src/**/*.{js,jsx,ts,tsx,astro,json,css,md}"
}

function help {
  echo "$0 <task> <args>"
  echo "Tasks:"
  compgen -A function | cat -n
}

TIMEFORMAT="Task completed in %3lR"
time "${@:-help}"
